# ── 应用配置 ──────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── 抖音小程序配置 ─────────────────────────────────────────────
APP_ID=tt4d553be8d3318e9402
# 在抖音开放平台 -> 我的应用 -> 开发设置 中获取
APP_SECRET=your_app_secret_here

# ── JWT 配置 ───────────────────────────────────────────────────
# 生产环境请使用随机长字符串，例如：openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_secret_in_production

# ── 数据库配置 ─────────────────────────────────────────────────
# 抖音云托管 MySQL 连接信息（在云托管控制台 -> 数据库 中查看）
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=sudoku_challenge
